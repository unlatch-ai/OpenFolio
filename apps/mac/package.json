{
  "name": "@openfolio/mac",
  "version": "0.2.2",
  "private": true,
  "type": "module",
  "main": "out/main/main.js",
  "scripts": {
    "build:contacts-helper": "mkdir -p bin && swiftc native/contacts-bridge.swift -framework Contacts -o bin/openfolio-contacts-bridge",
    "predev": "pnpm run build:contacts-helper",
    "prebuild": "pnpm run build:contacts-helper",
    "predist:mac": "pnpm run build:contacts-helper",
    "prerelease:mac": "pnpm run build:contacts-helper",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run test",
    "dist:mac": "electron-builder --mac dmg zip --publish never",
    "release:mac": "electron-builder --mac dmg zip --publish always"
  },
  "dependencies": {
    "@ai-sdk/react": "^1.2.8",
    "@convex-dev/auth": "^0.0.91",
    "@openfolio/core": "workspace:*",
    "@openfolio/hosted": "workspace:*",
    "@openfolio/mcp": "workspace:*",
    "@openfolio/shared-tokens": "workspace:^",
    "@openfolio/shared-types": "workspace:*",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-slot": "^1.2.3",
    "ai": "^4.3.19",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "convex": "^1.25.4",
    "electron-updater": "^6.6.2",
    "lucide-react": "^0.542.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "tailwind-merge": "^3.3.1"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.1.13",
    "@types/react": "^19.1.12",
    "@types/react-dom": "^19.1.9",
    "@vitejs/plugin-react": "^5.0.2",
    "electron": "^38.1.0",
    "electron-builder": "^26.0.12",
    "electron-vite": "^4.0.0",
    "tailwindcss": "^4.1.13",
    "vite": "^7.1.3"
  },
  "build": {
    "appId": "ai.openfolio.mac",
    "productName": "OpenFolio",
    "icon": "build/icon.icns",
    "files": [
      "out/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "bin/openfolio-contacts-bridge",
        "to": "bin/openfolio-contacts-bridge"
      }
    ],
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "publish": [
      {
        "provider": "github",
        "owner": "unlatch-ai",
        "repo": "OpenFolio"
      }
    ],
    "electronUpdaterCompatibility": ">=2.16",
    "mac": {
      "category": "public.app-category.productivity",
      "hardenedRuntime": true,
      "icon": "build/icon.icns",
      "extendInfo": {
        "NSContactsUsageDescription": "OpenFolio imports your contacts locally so phone numbers and email addresses resolve to real people on this Mac."
      },
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.inherit.plist",
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}
