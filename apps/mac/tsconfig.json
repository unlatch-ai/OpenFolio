{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "jsx": "react-jsx",
    "types": ["node", "vite/client", "electron"],
    "rootDir": "../..",
    "paths": {
      "@/*": ["apps/mac/src/*"],
      "@openfolio/shared-types": ["packages/shared-types/src/index.ts"],
      "@openfolio/core": ["packages/core/src/index.ts"],
      "@openfolio/mcp": ["packages/mcp/src/index.ts"],
      "@openfolio/hosted": ["packages/hosted/src/index.ts"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "electron.vite.config.ts"]
}
